{
    "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
    "files": {
        "includes": ["src/**/*", "web/*"]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "style": {
                "useTemplate": {
                    "level": "error",
                    "fix": "safe"
                }
            }
        }
    },
    "javascript": {
        "formatter": {
            "enabled": true,
            "lineWidth": 120,
            "quoteStyle": "single"
        }
    },
    "css": {
        "formatter": {
            "enabled": true
        }
    },
    "html": {
        "formatter": {
            "enabled": true,
            "indentWidth": 2,
            "lineWidth": 120,
            "bracketSameLine": true,
            "indentScriptAndStyle": true
        }
    }
}
